{
  "name": "ordpaw",
  "version": "0.0.2",
  "description": "OrdPaw — A powerful AI/Agent client",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "start": "turbo run start",
    "dev:server": "turbo run dev --filter=@ordpaw/server",
    "dev:client": "turbo run dev --filter=@ordpaw/client"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "turbo": "^2.9.18"
  }
}