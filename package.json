{
  "name": "ordpaw",
  "version": "0.0.3",
  "description": "OrdPaw — A powerful AI/Agent client",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @ordpaw/server dev",
    "dev:client": "pnpm --filter @ordpaw/client dev",
    "test": "pnpm -r test",
    "test:server": "pnpm --filter @ordpaw/server test",
    "test:client": "pnpm --filter @ordpaw/client test",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,mjs,json,md}\"",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.0",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.9",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "vitest": "^1.6.0"
  }
}
